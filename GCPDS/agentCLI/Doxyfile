# Doxyfile 1.9 - Agents CLI consolidated documentation
# Minimal Doxygen config to generate HTML pages from repository markdown files

PROJECT_NAME           = "Agents CLI — Consolidated Docs"
PROJECT_BRIEF          = "Consolidated documentation pages: README, basisReadme, ROLE-BASED_GUIDE, C-Collab-Env-Guide"

# Absolute output directory to avoid path resolution issues when invoking doxygen from any cwd
OUTPUT_DIRECTORY       = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/docs/doxygen
CREATE_SUBDIRS         = YES

# Generate only HTML (no LaTeX/PDF)
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES

# Reduce noise during generation
QUIET                 = YES
WARNINGS              = NO
WARN_IF_UNDOCUMENTED  = NO

# Input files (absolute paths to avoid resolution problems)
INPUT                  = \
  D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/README.md \
  D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/C-Collab-Env-Guide.md \
  D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/ANE2/maintenance/qualityAssurance/ROLE-BASED_GUIDE.md \
  D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/wellPrompt/README.md \
  D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/ANE2/maintenance/qualityAssurance/docs/reference/deploymentGuide.md 



# Patterns and formats
FILE_PATTERNS          = *.md
RECURSIVE              = NO
USE_MDFILE_AS_MAINPAGE = README.md
MARKDOWN_SUPPORT       = YES
# Avoid EXTENSION_MAPPING to prevent compatibility errors with some Doxygen versions
INPUT_ENCODING         = UTF-8
STRIP_FROM_PATH        = D:/wnOs/wsp/CODE/work/PersonalStuff
FULL_PATH_NAMES        = NO

# Presentation
SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
TAB_SIZE               = 4

# Keep output minimal and focused: do not document code symbols
EXTRACT_ALL            = NO

# End of Doxyfile
