# Doxyfile 1.9 - GCPDSenv Consolidated Documentation

PROJECT_NAME           = "GCPDSenv"
PROJECT_BRIEF          = "Consolidated environment documentation: Documentation, Hardware, Software, and Maintenance"

# Absolute output directory - Corrected to root docs for GitHub Pages
OUTPUT_DIRECTORY       = D:/wnOs/wsp/CODE/work/PersonalStuff/docs
CREATE_SUBDIRS         = NO

# Generate only HTML
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO
HTML_OUTPUT            = .
GENERATE_TREEVIEW      = YES

# Reduce noise
QUIET                 = YES
WARNINGS              = NO
WARN_IF_UNDOCUMENTED  = NO

# Input files - Tracking the entire GCPDS folder recursively
INPUT                  = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS
RECURSIVE              = YES
FILE_PATTERNS          = *.md

# Main page configuration
USE_MDFILE_AS_MAINPAGE = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/README.md

# Formatting and Support
MARKDOWN_SUPPORT       = YES
INPUT_ENCODING         = UTF-8
STRIP_FROM_PATH        = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS
FULL_PATH_NAMES        = NO

# Presentation
SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
TAB_SIZE               = 4
EXTRACT_ALL            = NO

# Extra files to include in HTML output
HTML_EXTRA_FILES       = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/paper.pdf

# Exclude unnecessary folders if needed
EXCLUDE                = D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/docs/doxygen \
                         D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/agentCLI/wellPrompt/.cache \
                         D:/wnOs/wsp/CODE/work/PersonalStuff/GCPDS/ANE2/maintenance/qualityAssurance/.cache
